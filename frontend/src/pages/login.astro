---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <!-- Menú de Navegación Simple -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <a
          href="/"
          style="text-decoration:none; color:inherit; display:flex; align-items:center; gap:0.5rem;"
        >
          <span class="icon">🥑</span>
          NutriWeb <span class="year">2026</span>
        </a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/alimentos">Alimentos</a></li>
        <li><a href="/plan">Plan Nutricional</a></li>
      </ul>
      <span id="login-btn"></span>
    </div>
  </nav>

  <main class="container login-container">
    <div class="card login-card">
      <div
        class="card-header"
        style="justify-content:center; margin-bottom:2rem;"
      >
        <div class="server-icon">🔐</div>
        <h2>Iniciar Sesión</h2>
      </div>

      <form id="login-form" class="login-form">
        <div class="form-group">
          <label for="email">Correo Electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="tu@email.com"
            class="input-field"
          />
        </div>

        <div class="form-group">
          <label for="password">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="••••••••"
            class="input-field"
          />
        </div>

        <div id="login-error" class="error-msg" style="display: none;"></div>

        <button
          type="submit"
          class="btn-primary"
          style="width: 100%; margin-top: 1rem;"
        >
          Ingresar a NutriWeb
        </button>

        <p
          style="text-align: center; margin-top: 1.5rem; font-size: 0.95rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem;"
        >
          ¿Eres nuevo? <a
            href="/register"
            style="color: var(--primary); font-weight: 600; text-decoration: none;"
            >Crear cuenta</a
          >
        </p>
      </form>
    </div>
  </main>
</Layout>

<style>
  .login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding-top: 4rem;
    background-color: transparent;
  }

  .login-card {
    max-width: 400px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border-radius: 16px;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-weight: 500;
    color: var(--text-main);
    font-size: 0.85rem;
  }
  @media (max-width: 480px) {
    .login-container {
      padding: 6rem 1rem 2rem 1rem;
    }
    .login-card {
      padding: 1.5rem;
    }
  }
</style>

<script>
  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const errorMsg = document.getElementById("login-error");

  if (loginForm && errorMsg) {
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorMsg.style.display = "none";

      const emailInput = document.getElementById("email") as HTMLInputElement;
      const passwordInput = document.getElementById(
        "password",
      ) as HTMLInputElement;

      if (!emailInput || !passwordInput) return;

      const email = emailInput.value;
      const password = passwordInput.value;

      try {
        const response = await fetch(
          `${import.meta.env.PUBLIC_API_URL}/api/auth/login`,
          {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email, password }),
          },
        );

        if (!response.ok) {
          throw new Error("Credenciales inválidas");
        }

        const data = await response.json();

        // Guardar nombre y email en localStorage
        localStorage.setItem("userName", data.nombre || "Usuario");
        localStorage.setItem("userEmail", email);

        // Redirigir al inicio para ver el cambio
        window.location.href = "/";
      } catch (err) {
        console.error("Error en login:", err);
        errorMsg.textContent = "Email o contraseña incorrectos.";
        errorMsg.style.display = "block";
      }
    });
  }
</script>
