---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <!-- Menú de Navegación -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <a
          href="/"
          style="text-decoration:none; color:inherit; display:flex; align-items:center; gap:0.5rem;"
        >
          <span class="icon">🥑</span>
          NutriWeb <span class="year">2026</span>
        </a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/alimentos" class="active">Alimentos</a></li>
        <li><a href="/plan">Plan Nutricional</a></li>
      </ul>
      <span id="login-btn"></span>
    </div>
  </nav>

  <main class="container alimentos-container">
    <div class="header-section">
      <span class="badge">Listado de alimentos</span>
      <h1 class="page-title">
        Catálogo de <span class="highlight">Alimentos</span>
      </h1>
      <p class="subtitle">
        Explora nuestra selección de ingredientes y conoce sus propiedades
        nutricionales para potenciar tu salud diaria.<br />
        Datos por cada 100 gr de alimento.
      </p>
    </div>

    <!-- loader -->
    <div id="loader" class="loader-container">
      <div class="pulse"></div>
      <p>Cargando información nutricional...</p>
    </div>

    <!-- error -->
    <div
      id="error-container"
      class="error-msg"
      style="display: none; max-width: 600px; margin: 0 auto;"
    >
    </div>

    <div id="alimentos-grid" class="alimentos-grid">
      <!-- Las tarjetas se inyectarán aquí JS -->
    </div>
  </main>
</Layout>

<style>
  .alimentos-container {
    padding-top: 8rem;
    min-height: 100vh;
    background-color: transparent;
  }

  .header-section {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem auto;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text-main);
  }

  .subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .loader-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    color: var(--text-muted);
    margin: 5rem 0;
  }

  .pulse {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    background-color: var(--bg-sub);
    border: 1px solid var(--border);
    animation: loader-pulse 1.5s infinite ease-in-out;
  }

  @keyframes loader-pulse {
    0% {
      transform: scale(0.9);
      opacity: 0.5;
    }
    50% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(0.9);
      opacity: 0.5;
    }
  }

  .alimentos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  @media (max-width: 768px) {
    .alimentos-container {
      padding-top: 6rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .page-title {
      font-size: 2.2rem;
    }
    .header-section {
      margin-bottom: 2rem;
    }
    .alimentos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  .food-card {
    background-color: #f4f9ff;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #d0e7ff;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 4px 12px rgba(35, 131, 226, 0.04);
  }

  .food-card:hover {
    background-color: #ebf5ff;
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(35, 131, 226, 0.08);
  }

  .food-name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-main);
    text-transform: capitalize;
  }

  .macro-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .macro-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid #d0e7ff;
  }

  .macro-item:last-child {
    border-bottom: none;
  }

  .macro-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .macro-value {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-main);
  }

  .cal-badge {
    display: inline-block;
    background: white;
    color: var(--primary);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid #d0e7ff;
    margin-bottom: 0.75rem;
    align-self: flex-start;
  }
</style>

<script>
  // Auth logic (similar to index)
  const userName = localStorage.getItem("userName");
  const loginBtn = document.getElementById("login-btn");

  if (loginBtn) {
    if (userName) {
      loginBtn.outerHTML = `
        <div class="user-menu" style="display: flex; align-items: center; gap: 0.75rem;">
          <a href="/evaluacion" class="user-avatar" style="width: 30px; height: 30px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; border: 1px solid var(--border); color: var(--primary); text-decoration: none; cursor: pointer;">
            👤
          </a>
          <span class="user-greeting" style="font-weight: 500; color: var(--text-main); font-size: 0.9rem;">
            ${userName}
          </span>
          <button id="logout-btn" class="btn-secondary" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;">Cerrar sesión</button>
        </div>
      `;

      document.getElementById("logout-btn")?.addEventListener("click", () => {
        localStorage.removeItem("userName");
        window.location.reload();
      });
    } else {
      loginBtn.innerHTML = `
        <a href="/login" class="btn-primary" style="text-decoration: none;">Ingresar</a>
      `;
    }
  }

  // Fetch foods
  async function fetchAlimentos() {
    const loader = document.getElementById("loader");
    const grid = document.getElementById("alimentos-grid");
    const errorContainer = document.getElementById("error-container");

    try {
      const res = await fetch(
        `${import.meta.env.PUBLIC_API_URL}/api/alimentos`,
        {
          cache: "no-store",
          headers: {
            "X-API-KEY": import.meta.env.PUBLIC_NUTRIWEB_API_KEY,
          },
        },
      );
      if (!res.ok) throw new Error("Error al conectar con la API de Alimentos");

      const alimentos = await res.json();

      if (loader) loader.style.display = "none";

      if (grid) {
        if (!alimentos || alimentos.length === 0) {
          grid.innerHTML =
            '<p style="grid-column: 1/-1; text-align: center; color: var(--text-muted); font-size: 1.1rem; background: var(--bg-card); padding: 3rem; border-radius: 1.5rem; border: 1px dashed rgba(255,255,255,0.1);">No hay registros de alimentos disponibles en este momento.</p>';
        } else {
          grid.innerHTML = alimentos
            .map(
              (food: any) => `
            <div class="food-card">
              <div class="cal-badge">${food.calorias} kcal</div>
              <div class="food-name">${food.nombre}</div>
              <div class="macro-list">
                <div class="macro-item">
                  <span class="macro-label">Proteínas</span>
                  <span class="macro-value">${food.proteinas}g</span>
                </div>
                <div class="macro-item">
                  <span class="macro-label">Carbohidratos</span>
                  <span class="macro-value">${food.carbohidratos}g</span>
                </div>
                <div class="macro-item">
                  <span class="macro-label">Grasas</span>
                  <span class="macro-value">${food.grasas}g</span>
                </div>
              </div>
            </div>
          `,
            )
            .join("");
        }

        // Show with fade-in effect
        requestAnimationFrame(() => {
          grid.style.opacity = "1";
        });
      }
    } catch (error) {
      console.error(error);
      if (loader) loader.style.display = "none";
      if (errorContainer) {
        errorContainer.textContent =
          "Hubo un problema al cargar los alimentos. Asegúrate de que el servidor esté en funcionamiento.";
        errorContainer.style.display = "block";
      }
    }
  }

  // Execute on load
  fetchAlimentos();
</script>
