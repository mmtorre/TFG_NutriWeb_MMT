---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <!-- Menú de Navegación -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <span class="icon">🥑</span>
        NutriWeb <span class="year">2026</span>
      </div>
      <ul class="nav-links">
        <li><a href="/" class="active">Inicio</a></li>
        <li><a href="/alimentos">Alimentos</a></li>
        <li><a href="/plan">Plan Nutricional</a></li>
      </ul>
      <span id="login-btn"></span>
    </div>
  </nav>

  <!-- Sección Hero -->
  <header id="inicio" class="hero">
    <div class="hero-content">
      <span class="badge">Tu vida, más saludable</span>
      <h1>
        Nutrición inteligente para <span class="highlight"
          >resultados reales</span>
      </h1>
      <div class="hero-description">
        <p class="intro-text">
          Una buena nutrición es el pilar fundamental para una vida plena. Una
          dieta equilibrada no solo previene enfermedades crónicas, sino que
          potencia tu nivel de energía y mejora tu bienestar físico y mental.
        </p>

        <div class="services-list">
          <div class="service-item">
            <span class="service-icon">🎯</span>
            <p>
              <strong>Consejos a tu medida:</strong> Recibe orientaciones nutricionales
              inteligentes basadas exclusivamente en los datos de tu perfil y objetivos
              físicos.
            </p>
          </div>
          <div class="service-item">
            <span class="service-icon">🥗</span>
            <p>
              <strong>Planes nutricionales automáticos:</strong> Diseñamos una dieta
              única para ti sugeriéndote un reparto de macronutrientes efectiva para
              mejorar tu salud y composición corporal.
            </p>
          </div>
        </div>
      </div>

      <div class="hero-buttons" style="margin-top: 2.5rem;">
        <a
          href="/login"
          id="hero-cta-btn"
          class="btn-primary large"
          style="text-decoration: none;">Empezar ahora</a
        >
      </div>
    </div>

    <!-- Decoración visual (Círculos difuminados de fondo) -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </header>

  <main class="container"></main>

  <footer>
    <p>© 2026 NutriWeb. Todos los derechos reservados.</p>
  </footer>

  <!-- Modal Personalizado -->
  <div id="custom-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
      <h3 style="margin-top: 0; font-size: 1.25rem;">¿Está seguro?</h3>
      <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5;">
        ¿Está seguro de que quiere cambiar sus datos? Esto recalculará tu plan nutricional actual.
      </p>
      <div class="modal-actions">
        <button id="modal-cancel" class="btn-secondary">Cancelar</button>
        <button id="modal-confirm" class="btn-primary">Sí, modificar</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-content {
    max-width: 900px;
    margin: 0 auto;
  }
  .intro-text {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 auto 3rem auto;
    max-width: 700px;
  }
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: left;
    background: var(--bg-sub);
    padding: 2.5rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    max-width: 800px;
    margin: 0 auto;
  }
  .service-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .service-icon {
    font-size: 1.2rem;
    background: white;
    color: var(--text-main);
    padding: 0.6rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .service-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .service-item strong {
    color: var(--text-main);
    display: block;
    margin-bottom: 0.2rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  /* Reducir espacio inferior */
  .hero {
    padding-bottom: 3rem;
  }
  footer {
    margin-top: 2rem;
  }
  .container {
    display: none;
  }

  /* Estilos del Modal */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2000;
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }
  .modal-content {
    background: var(--bg-main);
    padding: 2.5rem;
    border-radius: 12px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    border: 1px solid var(--border);
    animation: slideUp 0.3s ease;
  }
  .modal-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }
  .modal-actions button {
    flex: 1;
    font-size: 0.9rem;
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>

<script>
  // Lógica user login
  const userName = localStorage.getItem("userName");
  const loginBtn = document.getElementById("login-btn");

  if (loginBtn) {
    if (userName) {
      loginBtn.outerHTML = `
        <div class="user-menu" style="display: flex; align-items: center; gap: 0.75rem;">
          <span class="user-greeting" style="font-weight: 500; color: var(--text-main); display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;">
            <span style="opacity: 0.6;">👋</span> ${userName}
          </span>
          <button id="logout-btn" class="btn-secondary" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;">Cerrar sesión</button>
        </div>
      `;

      document.getElementById("logout-btn")?.addEventListener("click", () => {
        localStorage.removeItem("userName");
        window.location.reload();
      });
    } else {
      loginBtn.innerHTML = `
        <a href="/login" class="btn-primary" style="text-decoration: none; padding: 0.4rem 1rem; font-size: 0.85rem;">Ingresar</a>
      `;
    }
  }

  // Lógica Hero CTA Button dinámico y multibuton
  const heroCtaBtn = document.getElementById("hero-cta-btn") as HTMLAnchorElement;
  const heroButtons = document.querySelector(".hero-buttons");
  const userEmail = localStorage.getItem("userEmail");

  async function checkUserStatus() {
    if (!userName || !userEmail || !heroButtons) return;

    try {
      const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/userdata/${userEmail}`);
      if (response.ok) {
        const data = await response.json();
        
        if (data && data.peso > 0) {
          // El usuario ya tiene datos, mostrar los 3 botones
          heroButtons.innerHTML = `
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
              <a href="/evaluacion" class="btn-secondary" style="padding: 0.6rem 1.5rem;">Consultar datos</a>
              <a href="/plan" class="btn-primary" style="padding: 0.6rem 1.5rem;">Plan nutricional actual</a>
              <a href="#" id="modificar-btn" class="btn-secondary" style="padding: 0.6rem 1.5rem;">Modificar datos</a>
            </div>
          `;

          // Lógica del disclaimer para modificar datos
          document.getElementById("modificar-btn")?.addEventListener("click", (e) => {
            e.preventDefault();
            const modal = document.getElementById("custom-modal");
            const btnConfirm = document.getElementById("modal-confirm");
            const btnCancel = document.getElementById("modal-cancel");

            if (modal && btnConfirm && btnCancel) {
              modal.style.display = "flex";
              
              // Confirmar
              btnConfirm.addEventListener("click", () => {
                window.location.href = "/modificar-objetivo";
              }, { once: true }); // Usamos once para evitar múltiples listeners
              
              // Cancelar
              btnCancel.addEventListener("click", () => {
                modal.style.display = "none";
              }, { once: true });

              // Cerrar al hacer clic fuera
              modal.addEventListener("click", (event) => {
                if (event.target === modal) {
                  modal.style.display = "none";
                }
              }, { once: true });
            }
          });
        } else {
          // El usuario no tiene datos todavía
          if (heroCtaBtn) {
            heroCtaBtn.textContent = "Comenzar plan";
            heroCtaBtn.href = "/evaluacion";
          }
        }
      }
    } catch (err) {
      console.error("Error al verificar estado del usuario:", err);
    }
  }

  if (userName) {
    checkUserStatus();
  }
</script>
