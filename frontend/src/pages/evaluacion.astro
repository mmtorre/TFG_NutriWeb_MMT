---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <!-- Menú de Navegación Simple -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <a
          href="/"
          style="text-decoration:none; color:inherit; display:flex; align-items:center; gap:0.5rem;"
        >
          <span class="icon">🥑</span>
          NutriWeb <span class="year">2026</span>
        </a>
      </div>
      <ul class="nav-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/alimentos">Alimentos</a></li>
        <li><a href="/plan">Plan Nutricional</a></li>
      </ul>
      <span id="login-btn"></span>
    </div>
  </nav>

  <main class="container eval-container">
    <div class="card eval-card">
      <div class="card-header" style="text-align:center; margin-bottom:2.5rem;">
        <h2
          style="font-size: 1.75rem; margin-bottom: 0.5rem; font-weight: 700; color: var(--text-main);"
        >
          Evaluación Inicial
        </h2>
        <p
          style="margin:0; font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;"
        >
          Ingresa tus datos físicos para generar tu plan nutricional a medida.
        </p>
      </div>

      <form id="eval-form" class="eval-form">
        <!-- Flex container for two columns -->
        <div class="form-row">
          <div class="form-group flex-1">
            <label for="edad">Edad (años)</label>
            <input
              type="number"
              id="edad"
              name="edad"
              required
              min="1"
              max="120"
              placeholder="Ej: 25"
              class="input-field"
            />
          </div>

          <div class="form-group flex-1">
            <label for="sexo">Sexo biológico</label>
            <select id="sexo" name="sexo" required class="input-field">
              <option value="" disabled selected>Selecciona...</option>
              <option value="MASCULINO">Masculino</option>
              <option value="FEMENINO">Femenino</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group flex-1">
            <label for="peso">Peso (kg)</label>
            <input
              type="number"
              step="0.1"
              id="peso"
              name="peso"
              required
              min="20"
              max="300"
              placeholder="Ej: 70.5"
              class="input-field"
            />
          </div>

          <div class="form-group flex-1">
            <label for="altura">Altura (cm)</label>
            <input
              type="number"
              step="1"
              id="altura"
              name="altura"
              required
              min="50"
              max="250"
              placeholder="Ej: 175"
              class="input-field"
            />
          </div>
        </div>

        <div class="form-row" style="margin-top: 0.5rem;">
          <div class="form-group flex-1">
            <label for="nivelActividad">Nivel de Actividad Física</label>
            <select
              id="nivelActividad"
              name="nivelActividad"
              required
              class="input-field"
            >
              <option value="" disabled selected
                >¿Cuánto ejercicio haces?</option
              >
              <option value="SEDENTARIO">Sedentario (Poco o ningún)</option>
              <option value="LIGERO">Ligero (1-3 días/semana)</option>
              <option value="MODERADO">Moderado (3-5 días/semana)</option>
              <option value="ACTIVO">Activo (6-7 días/semana)</option>
              <option value="MUY_ACTIVO">Muy Activo (Intenso)</option>
            </select>
          </div>
          <div class="form-group flex-1">
            <label for="objetivo">Objetivo Principal</label>
            <select id="objetivo" name="objetivo" required class="input-field">
              <option value="" disabled selected>¿Qué buscas lograr?</option>
              <option value="GANAR_MASA">Ganar Masa Muscular</option>
              <option value="PERDIDA_GRASA">Pérdida de Grasa</option>
              <option value="MANTENIMIENTO">Mantenimiento</option>
            </select>
          </div>
        </div>

        <!-- Success & Error messages -->
        <div
          id="eval-success"
          class="success-msg"
          style="display: none; margin-top: 1rem;"
        >
          ¡Datos guardados con éxito! Generando plan...
        </div>
        <div
          id="eval-error"
          class="error-msg"
          style="display: none; margin-top: 1rem;"
        >
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="btn-primary large"
          style="width: 100%; margin-top: 1.5rem;"
        >
          Guardar y Crear Plan Nutricional
        </button>
      </form>

      <!-- Contenedor de Resultados -->
      <div
        id="results-container"
        class="results-container"
        style="display: none;"
      >
        <h3
          style="text-align:center; font-size: 1.25rem; margin-bottom: 2rem; font-weight: 600;"
        >
          Resumen de tu Perfil Nutricional
        </h3>

        <div class="summary-section">
          <h4 class="summary-title">Tus Datos Estructurales:</h4>
          <div class="summary-data">
            <div class="data-item">
              <span>Edad:</span>
              <strong id="sum-edad">--</strong> años
            </div>
            <div class="data-item">
              <span>Sexo:</span>
              <strong id="sum-sexo">--</strong>
            </div>
            <div class="data-item">
              <span>Peso:</span>
              <strong id="sum-peso">--</strong> kg
            </div>
            <div class="data-item">
              <span>Altura:</span>
              <strong id="sum-altura">--</strong> cm
            </div>
            <div class="data-item">
              <span>Actividad:</span>
              <strong id="sum-actividad">--</strong>
            </div>
            <div class="data-item">
              <span>Objetivo:</span>
              <strong id="sum-objetivo">--</strong>
            </div>
          </div>
        </div>

        <div class="results-grid">
          <div class="result-card">
            <div class="result-label">IMC</div>
            <div class="result-value" id="res-imc">--</div>
          </div>
          <div class="result-card">
            <div class="result-label">Calorías Diarias</div>
            <div class="result-value" id="res-calorias">--</div>
          </div>
          <div class="result-card">
            <div class="result-label">Masa Muscular</div>
            <div class="result-value" id="res-masa">--</div>
          </div>
        </div>

        <div class="results-actions">
          <a href="/consejos" class="btn-secondary">Consejos generales</a>
          <a href="/plan" class="btn-primary">Plan nutricional individual</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .eval-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 4rem;
    background-color: var(--bg-sub);
  }

  .eval-card {
    max-width: 600px;
  }

  .eval-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: flex;
    gap: 1.25rem;
  }

  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
      gap: 1.25rem;
    }
  }

  .flex-1 {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-weight: 500;
    color: var(--text-main);
    font-size: 0.85rem;
  }

  .results-container {
    animation: fadeIn 0.4s ease;
  }

  .summary-section {
    background-color: var(--bg-sub);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .summary-title {
    margin-top: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  .summary-data {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
    font-size: 0.9rem;
  }

  .data-item span {
    color: var(--text-muted);
  }

  .data-item strong {
    color: var(--text-main);
    font-weight: 500;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .result-card {
    background-color: var(--bg-main);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    text-align: center;
  }

  .result-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .results-actions {
    display: flex;
    gap: 1rem;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Lógica user login & navbar
  const userName = localStorage.getItem("userName");
  const userEmail = localStorage.getItem("userEmail");
  const loginBtn = document.getElementById("login-btn");

  // Redirigir al login si no está autenticado
  if (!userName || !userEmail) {
    window.location.href = "/login";
  } else if (loginBtn) {
    loginBtn.outerHTML = `
      <div class="user-menu" style="display: flex; align-items: center; gap: 0.75rem;">
        <span class="user-greeting" style="font-weight: 500; color: var(--text-main); display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;">
          <span style="opacity: 0.6;">👋</span> ${userName}
        </span>
        <button id="logout-btn" class="btn-secondary" style="padding: 0.3rem 0.75rem; font-size: 0.8rem;">Cerrar sesión</button>
      </div>
    `;

    document.getElementById("logout-btn")?.addEventListener("click", () => {
      localStorage.removeItem("userName");
      localStorage.removeItem("userEmail");
      window.location.href = "/";
    });
  }

  // Enviar formulario
  const evalForm = document.getElementById("eval-form") as HTMLFormElement;
  const errorMsg = document.getElementById("eval-error");
  const successMsg = document.getElementById("eval-success");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  // Cargar datos existentes al iniciar
  window.addEventListener("DOMContentLoaded", async () => {
    if (!userEmail) return;

    try {
      const response = await fetch(
        `${import.meta.env.PUBLIC_API_URL}/api/userdata/${userEmail}`,
      );
      if (response.ok) {
        const data = await response.json();
        if (data && data.peso > 0) {
          // Si ya tiene datos, mostrar directamente los resultados
          showResults(data);
        }
      }
    } catch (err) {
      console.error("Error al cargar datos existentes:", err);
    }
  });

  function showResults(data: any) {
    if (evalForm) evalForm.style.display = "none";

    const headerText = document.querySelector(".card-header p");
    if (headerText)
      headerText.textContent =
        "Consulta tus últimos cálculos y parámetros físicos.";

    // Inyectar datos en el resumen
    document.getElementById("sum-edad")!.textContent = String(
      data.edad || "--",
    );
    document.getElementById("sum-sexo")!.textContent = String(
      data.sexo || "--",
    );
    document.getElementById("sum-peso")!.textContent = String(
      data.peso || "--",
    );
    document.getElementById("sum-altura")!.textContent = String(
      data.altura || "--",
    );
    document.getElementById("sum-actividad")!.textContent = String(
      data.nivelActividad || "--",
    ).replace("_", " ");
    document.getElementById("sum-objetivo")!.textContent = String(
      data.objetivo || "--",
    ).replace("_", " ");

    // Inyectar cálculos en DOM
    const resContainer = document.getElementById("results-container");
    if (resContainer) {
      document.getElementById("res-imc")!.textContent = (data.imc || 0).toFixed(
        1,
      );
      document.getElementById("res-calorias")!.textContent =
        `${data.calorias || 0} kcal`;
      document.getElementById("res-masa")!.textContent =
        `${(data.masaMuscular || 0).toFixed(1)} kg`;

      resContainer.style.display = "block";
    }
  }

  if (evalForm && errorMsg && successMsg && submitBtn) {
    evalForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      errorMsg.style.display = "none";
      successMsg.style.display = "none";
      submitBtn.disabled = true;
      submitBtn.textContent = "Guardando...";

      const edadInput = document.getElementById("edad") as HTMLInputElement;
      const sexoInput = document.getElementById("sexo") as HTMLSelectElement;
      const pesoInput = document.getElementById("peso") as HTMLInputElement;
      const alturaInput = document.getElementById("altura") as HTMLInputElement;
      const actividadInput = document.getElementById(
        "nivelActividad",
      ) as HTMLSelectElement;
      const objetivoInput = document.getElementById(
        "objetivo",
      ) as HTMLSelectElement;

      if (
        !edadInput ||
        !sexoInput ||
        !pesoInput ||
        !alturaInput ||
        !actividadInput ||
        !objetivoInput
      )
        return;

      const payload = {
        email: userEmail,
        edad: parseInt(edadInput.value, 10),
        sexo: sexoInput.value,
        peso: parseFloat(pesoInput.value),
        altura: parseFloat(alturaInput.value),
        nivelActividad: actividadInput.value,
        objetivo: objetivoInput.value,
      };

      try {
        const response = await fetch(
          `${import.meta.env.PUBLIC_API_URL}/api/userdata`,
          {
            method: "POST", // Puede ser POST o PUT según el backend
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          },
        );

        if (!response.ok) {
          throw new Error("No se pudieron guardar los datos.");
        }

        const data = await response.json();

        // Esconder formulario y mostrar resultados
        evalForm.style.display = "none";

        const headerText = document.querySelector(".card-header p");
        if (headerText)
          headerText.textContent = "Hemos analizado tus datos correctamente.";

        // Inyectar datos en el resumen
        document.getElementById("sum-edad")!.textContent = String(
          data.edad || "--",
        );
        document.getElementById("sum-sexo")!.textContent = String(
          data.sexo || "--",
        );
        document.getElementById("sum-peso")!.textContent = String(
          data.peso || "--",
        );
        document.getElementById("sum-altura")!.textContent = String(
          data.altura || "--",
        );
        document.getElementById("sum-actividad")!.textContent = String(
          data.nivelActividad || "--",
        ).replace("_", " ");
        document.getElementById("sum-objetivo")!.textContent = String(
          data.objetivo || "--",
        ).replace("_", " ");

        // Inyectar cálculos en DOM
        const resContainer = document.getElementById("results-container");
        if (resContainer) {
          document.getElementById("res-imc")!.textContent = (
            data.imc || 0
          ).toFixed(1);
          document.getElementById("res-calorias")!.textContent =
            `${data.calorias || 0} kcal`;
          document.getElementById("res-masa")!.textContent =
            `${(data.masaMuscular || 0).toFixed(1)} kg`;

          resContainer.style.display = "block";
        }
      } catch (err) {
        console.error("Error al guardar userData:", err);
        errorMsg.textContent =
          "Error al intentar guardar tus datos. Inténtalo de nuevo.";
        errorMsg.style.display = "block";
        submitBtn.disabled = false;
        submitBtn.textContent = "Guardar y Crear Plan Nutricional";
      }
    });
  }
</script>
